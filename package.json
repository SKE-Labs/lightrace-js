{
  "name": "lightrace",
  "version": "0.1.2",
  "description": "Lightweight LLM tracing SDK with remote tool invocation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./integrations/langchain": {
      "import": "./dist/integrations/langchain.js",
      "types": "./dist/integrations/langchain.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@langchain/core": "^1.1.32",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.8.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{ts,json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@1.22.22",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SKE-Labs/lightrace-js.git"
  },
  "keywords": [
    "llm",
    "tracing",
    "observability",
    "langfuse",
    "opentelemetry",
    "tool-invocation"
  ],
  "author": "Lightrace Contributors",
  "engines": {
    "node": ">=20.0.0"
  }
}
